#!/bin/sh
# YggMesh Node — Zero-Touch First Boot Configuration
# This script runs once on first boot via uci-defaults mechanism.
# It configures: 802.11s WiFi mesh, dual-band WiFi (private AP), firewall zones, Yggdrasil overlay.

# ============================================================================
# 0. Constants and input parameters
# ============================================================================

# =================
# 0.1. Input parameters (strictly required, baked in by build.sh per build)
# =================

# DNS resolvers reachable over Yggdrasil; space-separated list of addresses
YGGDRASIL_DNS=$(cat /etc/yggmesh/inputs/yggdrasil_dns)

# Initial root password set on first boot (user should change via LuCI or passwd)
DEFAULT_ROOT_PASSWORD=$(cat /etc/yggmesh/inputs/root_password)

# Yggdrasil peers to bake in (space-separated list of peer URIs)
YGGDRASIL_PEERS=$(cat /etc/yggmesh/inputs/yggdrasil_peers)

# Client AP SSID for end-user devices
PRIVATE_SSID=$(cat /etc/yggmesh/inputs/private_ssid)

# 802.11s mesh identifier
MESH_ID=$(cat /etc/yggmesh/inputs/mesh_id)

# SAE key for 802.11s mesh peering
MESH_KEY=$(cat /etc/yggmesh/inputs/mesh_key)

# Yggdrasil fixed peering port
YGG_PORT=$(cat /etc/yggmesh/inputs/ygg_port)

# Cleanup sensitive build inputs immediately after reading into memory
rm -rf /etc/yggmesh/inputs

# =================
# 0.2. Constants
# =================

# Fixed router IPv4 address for local WiFi
PRIV_IP="10.0.0.1"

# ============================================================================
# 1. IDENTITY GENERATION
# ============================================================================

# Fresh flash — detect MAC from hardware
# Get hardware MAC with retry (some devices initialize NICs slowly at first boot)
BASE_MAC=""
for attempt in 1 2 3 4 5; do
    for iface in br-lan eth0 eth1 eth2; do
        mac=$(cat /sys/class/net/$iface/address 2>/dev/null)
        if [ -n "$mac" ] && [ "$mac" != "00:00:00:00:00:00" ]; then
            BASE_MAC="$mac"
            break 2
        fi
    done
    [ "$attempt" -lt 5 ] && sleep 1
done
# Fallback: random locally-administered MAC (02:xx:xx:xx:xx:xx)
if [ -z "$BASE_MAC" ] || [ "$BASE_MAC" = "00:00:00:00:00:00" ]; then
    BASE_MAC=$(hexdump -n 5 -e '/1 ":%02x"' /dev/urandom | sed 's/^:/02:/')
fi

# Last 4 hex digits of MAC for unique suffix
NODE_SUFFIX=$(echo "$BASE_MAC" | awk -F: '{print toupper($5$6)}')
HOSTNAME="YggMesh-${NODE_SUFFIX}"

# ============================================================================
# 2. ROOT PASSWORD
# ============================================================================

# Set default root password (user should change via LuCI or passwd)
if [ -n "$DEFAULT_ROOT_PASSWORD" ]; then
    if echo -e "${DEFAULT_ROOT_PASSWORD}\n${DEFAULT_ROOT_PASSWORD}" | passwd root >/dev/null 2>&1; then
        logger -t yggmesh "Default root password set"
    else
        logger -t yggmesh "Warning: failed to set default root password"
    fi
fi

# ============================================================================
# 3. NETWORK CONFIGURATION
# ============================================================================

# --- Port mapping (written by build.sh per device) ---
PORT_MAP=$(cat /etc/yggmesh/port_map 2>/dev/null || echo "eth0:lan eth1:wan")
# Parse port map (e.g. "wan:wan lan1:lan lan2:lan lan3:lan")
LAN_PORTS=""
WAN_DEV=""
for mapping in $PORT_MAP; do
    port="${mapping%%:*}"
    role="${mapping##*:}"
    if [ "$role" = "lan" ]; then
        LAN_PORTS="${LAN_PORTS:+$LAN_PORTS }$port"
    elif [ "$role" = "wan" ]; then
        WAN_DEV="$port"
    fi
done
[ -z "$LAN_PORTS" ] && LAN_PORTS="eth0"
[ -z "$WAN_DEV" ] && WAN_DEV="eth1"

# Delete default OpenWrt br-lan/lan (conflicts with our br-private)
uci -q delete network.lan 2>/dev/null || true
# Find and delete br-lan device
for i in 0 1 2 3 4; do
    name=$(uci -q get "network.@device[$i].name" 2>/dev/null)
    if [ "$name" = "br-lan" ]; then
        uci delete "network.@device[$i]"
        break
    fi
done

uci batch <<-NET_EOF
# --- loopback: Standard local routing interface ---
set network.loopback=interface
set network.loopback.device='lo'
set network.loopback.proto='static'
set network.loopback.ipaddr='127.0.0.1'
set network.loopback.netmask='255.0.0.0'

# --- private_dev: Physical bridge grouping LAN ethernet ports and the Client AP Wi-Fi ---
set network.private_dev=device
set network.private_dev.type='bridge'
set network.private_dev.name='br-private'
set network.private_dev.empty='1'
set network.private_dev.igmp_snooping='0'
delete network.private_dev.ports

# --- mesh: Layer 2 interface for raw 802.11s radios. proto='unmanaged' ensures it gets an IPv6 Link-Local address ---
set network.mesh=interface
set network.mesh.proto='unmanaged'

# --- private: Layer 3 logical interface for br-private, providing the local router IP to clients ---
set network.private=interface
set network.private.device='br-private'
set network.private.proto='static'
set network.private.ipaddr='${PRIV_IP}'
set network.private.netmask='255.255.255.0'

# --- wan: Upstream internet port (DHCP client) to connect to global Yggdrasil peers ---
set network.wan=interface
set network.wan.device='${WAN_DEV}'
set network.wan.proto='dhcp'
NET_EOF

# Add LAN ports to private bridge (DSA: lan1-4, non-DSA: eth0)
for port in $LAN_PORTS; do
    uci add_list network.private_dev.ports="$port"
done

uci commit network

# ============================================================================
# 5. WIRELESS CONFIGURATION
# ============================================================================

# Detect radios dynamically
RADIOS=$(uci show wireless | grep '=wifi-device' | cut -d'=' -f1 | cut -d'.' -f2)

# Determine which radio is 2.4GHz and which is 5GHz
RADIO_2G=""
RADIO_5G=""

for radio in $RADIOS; do
    band=$(uci -q get "wireless.${radio}.band" 2>/dev/null || echo "")
    htmode=$(uci -q get "wireless.${radio}.htmode" 2>/dev/null || echo "")

    if [ "$band" = "2g" ]; then
        RADIO_2G="$radio"
    elif [ "$band" = "5g" ]; then
        RADIO_5G="$radio"
    else
        # Fallback: detect from htmode or channel
        channel=$(uci -q get "wireless.${radio}.channel" 2>/dev/null || echo "0")
        if [ "$channel" -le 14 ] 2>/dev/null; then
            RADIO_2G="$radio"
        else
            RADIO_5G="$radio"
        fi
    fi
done

# Fallback: if only one radio detected, use it for both
DUAL_BAND=true
if [ -z "$RADIO_2G" ] && [ -n "$RADIO_5G" ]; then
    RADIO_2G="$RADIO_5G"
    DUAL_BAND=false
fi
if [ -z "$RADIO_5G" ] && [ -n "$RADIO_2G" ]; then
    RADIO_5G="$RADIO_2G"
    DUAL_BAND=false
fi

# Remove all existing wifi-iface sections
while uci -q delete wireless.@wifi-iface[0]; do :; done

# Enable radios and set fixed channels (all nodes must share same channel for mesh peering)
for radio in $RADIOS; do
    uci -q delete "wireless.${radio}.disabled" 2>/dev/null || true
done

# Fixed channels — all mesh nodes must be on the same channel per band
# 2.4GHz: channel 1 (DFS-free, least congested of 1/6/11)
# 5GHz: channel 36 (DFS-free, universal chipset support)
if [ -n "$RADIO_2G" ]; then
    uci set "wireless.${RADIO_2G}.channel=1"
fi
if [ -n "$RADIO_5G" ] && [ "$DUAL_BAND" = "true" ]; then
    uci set "wireless.${RADIO_5G}.channel=36"
fi

# --- 2.4GHz radio: always mesh backhaul; AP only if single-band ---
if [ -n "$RADIO_2G" ]; then
    # Mesh interface on 2.4GHz (always — dedicated backhaul on all devices)
    uci batch <<-WIFI_2G_MESH
set wireless.mesh_2g=wifi-iface
set wireless.mesh_2g.device='${RADIO_2G}'
set wireless.mesh_2g.mode='mesh'
set wireless.mesh_2g.mesh_id='${MESH_ID}'
set wireless.mesh_2g.mesh_fwding='0'
set wireless.mesh_2g.encryption='sae'
set wireless.mesh_2g.key='${MESH_KEY}'
set wireless.mesh_2g.network='mesh'
WIFI_2G_MESH

    # Private AP on 2.4GHz — single-band devices only
    # (dual-band devices dedicate 2.4GHz to mesh and use 5GHz for client AP)
    if [ "$DUAL_BAND" = "false" ]; then
        uci batch <<-WIFI_2G_PRIV
set wireless.private_2g=wifi-iface
set wireless.private_2g.device='${RADIO_2G}'
set wireless.private_2g.mode='ap'
set wireless.private_2g.ssid='${PRIVATE_SSID}'
set wireless.private_2g.encryption='none'
set wireless.private_2g.network='private'
WIFI_2G_PRIV
    fi
fi

# --- 5GHz radio: AP only (dual-band devices) — dedicated client radio ---
if [ -n "$RADIO_5G" ] && [ "$DUAL_BAND" = "true" ]; then
    uci batch <<-WIFI_5G_PRIV
set wireless.private_5g=wifi-iface
set wireless.private_5g.device='${RADIO_5G}'
set wireless.private_5g.mode='ap'
set wireless.private_5g.ssid='${PRIVATE_SSID}'
set wireless.private_5g.encryption='none'
set wireless.private_5g.network='private'
WIFI_5G_PRIV
fi

uci commit wireless

# ============================================================================
# 6. FIREWALL CONFIGURATION
# ============================================================================

# Reset firewall to clean state
while uci -q delete firewall.@zone[0]; do :; done
while uci -q delete firewall.@forwarding[0]; do :; done
while uci -q delete firewall.@rule[0]; do :; done
while uci -q delete firewall.@redirect[0]; do :; done

uci batch <<-FW_EOF
# --- Zone: lan (private network) ---
set firewall.lan=zone
set firewall.lan.name='lan'
set firewall.lan.input='ACCEPT'
set firewall.lan.output='ACCEPT'
set firewall.lan.forward='ACCEPT'
add_list firewall.lan.network='private'

# --- Zone: mesh (raw 802.11s links for Yggdrasil) ---
set firewall.mesh_zone=zone
set firewall.mesh_zone.name='mesh'
set firewall.mesh_zone.input='REJECT'
set firewall.mesh_zone.output='ACCEPT'
set firewall.mesh_zone.forward='REJECT'
add_list firewall.mesh_zone.network='mesh'

# Allow incoming Yggdrasil IPv6 traffic on mesh
set firewall.allow_ygg_mesh=rule
set firewall.allow_ygg_mesh.name='Allow-Yggdrasil-Mesh'
set firewall.allow_ygg_mesh.src='mesh'
set firewall.allow_ygg_mesh.proto='tcp udp'
set firewall.allow_ygg_mesh.dest_port='${YGG_PORT}'
set firewall.allow_ygg_mesh.family='ipv6'
set firewall.allow_ygg_mesh.target='ACCEPT'

# Allow IPv6 Link-Local routing (fe80::) unconditionally on mesh for Yggdrasil beacons
set firewall.allow_ll_mesh=rule
set firewall.allow_ll_mesh.name='Allow-LinkLocal-Mesh'
set firewall.allow_ll_mesh.src='mesh'
set firewall.allow_ll_mesh.src_ip='fe80::/10'
set firewall.allow_ll_mesh.family='ipv6'
set firewall.allow_ll_mesh.target='ACCEPT'

# Allow IPv6 Multicast (ff02::) unconditionally on mesh for Yggdrasil discovery
set firewall.allow_mcast_mesh=rule
set firewall.allow_mcast_mesh.name='Allow-Multicast-Mesh'
set firewall.allow_mcast_mesh.src='mesh'
set firewall.allow_mcast_mesh.dest_ip='ff00::/8'
set firewall.allow_mcast_mesh.family='ipv6'
set firewall.allow_mcast_mesh.target='ACCEPT'

# Allow ICMPv6 on mesh (needed for IPv6 Neighbor Discovery and SLAAC)
set firewall.allow_icmpv6_mesh=rule
set firewall.allow_icmpv6_mesh.name='Allow-ICMPv6-Mesh'
set firewall.allow_icmpv6_mesh.src='mesh'
set firewall.allow_icmpv6_mesh.proto='icmp'
set firewall.allow_icmpv6_mesh.family='ipv6'
set firewall.allow_icmpv6_mesh.target='ACCEPT'

# --- Zone: wan ---
set firewall.wan=zone
set firewall.wan.name='wan'
set firewall.wan.input='REJECT'
set firewall.wan.output='ACCEPT'
set firewall.wan.forward='REJECT'
set firewall.wan.masq='1'
set firewall.wan.mtu_fix='1'
add_list firewall.wan.network='wan'

# --- Forwarding: lan → wan ---
set firewall.fwd_lan_wan=forwarding
set firewall.fwd_lan_wan.src='lan'
set firewall.fwd_lan_wan.dest='wan'

# --- Standard WAN input rules ---
set firewall.allow_dhcp_renew=rule
set firewall.allow_dhcp_renew.name='Allow-DHCP-Renew'
set firewall.allow_dhcp_renew.src='wan'
set firewall.allow_dhcp_renew.proto='udp'
set firewall.allow_dhcp_renew.dest_port='68'
set firewall.allow_dhcp_renew.target='ACCEPT'
set firewall.allow_dhcp_renew.family='ipv4'

set firewall.allow_ping=rule
set firewall.allow_ping.name='Allow-Ping'
set firewall.allow_ping.src='wan'
set firewall.allow_ping.proto='icmp'
set firewall.allow_ping.icmp_type='echo-request'
set firewall.allow_ping.target='ACCEPT'
FW_EOF

uci commit firewall

# ============================================================================
# 7. DHCP / DNS CONFIGURATION
# ============================================================================

# Remove existing DHCP pools that may conflict
uci -q delete dhcp.lan 2>/dev/null || true

uci batch <<-DHCP_EOF
set dhcp.private=dhcp
set dhcp.private.interface='private'
set dhcp.private.start='100'
set dhcp.private.limit='150'
set dhcp.private.leasetime='12h'
# Advertise router's own IPv4 for DNS
# Note: DHCPv4 option 6 cannot be an IPv6 address
add_list dhcp.private.dhcp_option='6,${PRIV_IP}'

# Configure Dnsmasq to use Yggdrasil DNS, alongside reliable public DNS
# This bypasses potentially broken/hijacked ISP DNS so public peers always resolve
set dhcp.@dnsmasq[0].noresolv='1'
set dhcp.@dnsmasq[0].localuse='1'
add_list dhcp.@dnsmasq[0].server='1.1.1.1'
add_list dhcp.@dnsmasq[0].server='8.8.8.8'
DHCP_EOF

# Yggdrasil DNS resolvers, prepended only when baked in at build time
for yggdrasil_dns in $YGGDRASIL_DNS; do
    uci add_list dhcp.@dnsmasq[0].server="$yggdrasil_dns"
done

uci commit dhcp

# ============================================================================
# 8. SYSTEM SETTINGS
# ============================================================================

uci batch <<-SYS_EOF
set system.@system[0].hostname='${HOSTNAME}'
set system.@system[0].timezone='UTC0'
set system.@system[0].zonename='UTC'
set system.@system[0].log_proto='udp'
set system.@system[0].conloglevel='7'
set system.@system[0].cronloglevel='9'
SYS_EOF

# NTP: use public pool as primary servers
uci -q delete system.ntp.server
uci add_list system.ntp.server='0.openwrt.pool.ntp.org'
uci add_list system.ntp.server='1.openwrt.pool.ntp.org'
uci add_list system.ntp.server='2.openwrt.pool.ntp.org'
uci set system.ntp.enabled='1'

uci commit system


# =========================================================================
# 8. YGGDRASIL OVERLAY NETWORK
# =========================================================================

# Generate a new key pair for Yggdrasil
YGG_PRIVKEY=$(yggdrasil -genconf 2>/dev/null | grep 'PrivateKey' | awk -F': ' '{print $2}')

# Configure Yggdrasil interface natively via UCI
uci batch <<-YGG_EOF
set network.yggdrasil=interface
set network.yggdrasil.proto='yggdrasil'
set network.yggdrasil.private_key="${YGG_PRIVKEY}"
set network.yggdrasil.node_info_privacy='0'

set network.ygg_iface=yggdrasil_yggdrasil_interface
add_list network.ygg_iface.interface='.+'
set network.ygg_iface.beacon='1'
set network.ygg_iface.listen='1'
set network.ygg_iface.port='${YGG_PORT}'
YGG_EOF

# Bake in Yggdrasil peers (space-separated list) only when provided at build time
PEER_ID=1
for ygg_peer in $YGGDRASIL_PEERS; do
    uci set network.ygg_peer_${PEER_ID}=yggdrasil_yggdrasil_peer
    uci set network.ygg_peer_${PEER_ID}.address="$ygg_peer"
    PEER_ID=$((PEER_ID + 1))
done

uci commit network

# Yggdrasil firewall zone
uci batch <<-YGG_FW_EOF
set firewall.ygg_zone=zone
set firewall.ygg_zone.name='yggdrasil'
set firewall.ygg_zone.input='REJECT'
set firewall.ygg_zone.output='ACCEPT'
set firewall.ygg_zone.forward='REJECT'
add_list firewall.ygg_zone.network='yggdrasil'

# Allow ICMPv6 on Yggdrasil (Required)
set firewall.allow_icmpv6_ygg=rule
set firewall.allow_icmpv6_ygg.name='Allow ICMPv6 Ygg'
set firewall.allow_icmpv6_ygg.src='yggdrasil'
set firewall.allow_icmpv6_ygg.proto='icmp'
set firewall.allow_icmpv6_ygg.family='ipv6'
set firewall.allow_icmpv6_ygg.target='ACCEPT'

# Forwardings: LAN → Yggdrasil (outbound: private clients can reach Yggdrasil services)
set firewall.fwd_lan_ygg=forwarding
set firewall.fwd_lan_ygg.src='lan'
set firewall.fwd_lan_ygg.dest='yggdrasil'
YGG_FW_EOF

uci commit firewall

# Enable yggdrasil service
/etc/init.d/yggdrasil enable 2>/dev/null || true

# Temporary config for address generation
YGG_TMP=$(mktemp)
echo "{ PrivateKey: \"${YGG_PRIVKEY}\" }" > "$YGG_TMP"

# Get yggdrasil address
YGG_ADDR=$(yggdrasil -address -useconffile "$YGG_TMP" 2>/dev/null || echo "unknown")

# ============================================================================
# 9. YGGDRASIL IPv6
#     Private: 300::/64 SLAAC — devices reachable via Yggdrasil
# ============================================================================

# Extract Yggdrasil 300::/64 subnet
YGG_SUBNET=$(yggdrasil -subnet -useconffile "$YGG_TMP" 2>/dev/null)
rm -f "$YGG_TMP"

# YGG_SUBNET format: 300:xxxx:xxxx:xxxx::/64
YGG_SUBNET_PREFIX="${YGG_SUBNET%%::*}"  # 300:xxxx:xxxx:xxxx

if [ -n "$YGG_SUBNET_PREFIX" ]; then
    # Assign 300::/64 to PRIVATE interface
    # Private clients get globally-routable Yggdrasil addresses via SLAAC
    uci set network.private.ip6addr="${YGG_SUBNET_PREFIX}::1/64"
    uci commit network

    # Configure RA/SLAAC for private (odhcpd)
    uci batch <<-PRIV6_EOF
set dhcp.private.ra='server'
set dhcp.private.dhcpv6='disabled'
set dhcp.private.ra_management='0'
set dhcp.private.ra_default='1'
set dhcp.private.ra_slaac='1'
PRIV6_EOF
    # Advertise Yggdrasil DNS over RA only when baked in at build time
    for yggdrasil_dns in $YGGDRASIL_DNS; do
        uci add_list dhcp.private.dns="$yggdrasil_dns"
    done
    uci commit dhcp

    logger -t yggmesh "Private IPv6: ${YGG_SUBNET_PREFIX}::1/64 (SLAAC)"
else
    logger -t yggmesh "Warning: Could not extract Yggdrasil subnet"
fi

# ============================================================================
# 10. FINAL
# ============================================================================

# Log completion
logger -t yggmesh "First boot configuration complete"
logger -t yggmesh "Hostname: ${HOSTNAME}"
logger -t yggmesh "Private: ${PRIVATE_SSID} @ ${PRIV_IP}/24"
logger -t yggmesh "Mesh ID: ${MESH_ID}"
logger -t yggmesh "Yggdrasil: ${YGG_ADDR} (multicast discovery on br-private)"
logger -t yggmesh "Private IPv6: Yggdrasil 300::/64 SLAAC"

exit 0
